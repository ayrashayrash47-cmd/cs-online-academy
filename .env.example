# Copy this file to .env and fill in real values before running the app.
# See README.md for full setup instructions.

DATABASE_URL="file:./dev.db"

# --- CS Online Academy admin login ---
# CHANGE THESE before deploying.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme123"

# Random secret used to sign the admin session cookie. Generate a new one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-this-with-a-random-64-character-hex-string"
