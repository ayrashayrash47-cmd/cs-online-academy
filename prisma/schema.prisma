// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// A single enrollment submission: a student picking a plan and
// uploading proof of an out-of-band payment (EasyPaisa / bank transfer).
model Enrollment {
  id             Int      @id @default(autoincrement())
  fullName       String
  grade          String // "9" | "10"
  whatsapp       String
  email          String?
  plan           String // "math" | "all"
  paymentMethod  String // "easypaisa" | "bank"
  transactionId  String?
  screenshotPath String // relative path under /uploads
  status         String   @default("pending") // "pending" | "verified" | "rejected"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
